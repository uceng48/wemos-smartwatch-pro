<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Blok khusus untuk perangkat lokal yang tidak pakai HTTPS -->
    <domain-config cleartextTrafficPermitted="true">
        
        <!-- TARGET UTAMA: Wemos D1 (cocok persis dengan IP statisnya) -->
        <domain includeSubdomains="false">192.168.4.1</domain>
        
        <!-- Opsional: perangkat lokal lain di jaringan yang sama -->
        <domain includeSubdomains="false">192.168.100.101</domain>
        
        <!-- Untuk akses via mDNS (contoh: http://wemos.local) -->
        <domain includeSubdomains="true">local</domain>
        <domain includeSubdomains="true">localhost</domain>
        
    </domain-config>
    
    <!-- Aturan global: semua akses internet publik WAJIB HTTPS -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
